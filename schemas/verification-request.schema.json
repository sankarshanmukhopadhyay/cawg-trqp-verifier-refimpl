{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "asset_id",
    "integrity_ok",
    "entity_id",
    "authority_id",
    "action",
    "resource",
    "context"
  ],
  "properties": {
    "asset_id": {
      "type": "string"
    },
    "integrity_ok": {
      "type": "boolean"
    },
    "entity_id": {
      "type": "string"
    },
    "authority_id": {
      "type": "string"
    },
    "issuer_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "action": {
      "type": "string"
    },
    "resource": {
      "type": "string"
    },
    "context": {
      "type": "object"
    },
    "process_evidence": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "verified": {
          "type": "boolean"
        },
        "process_type": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "evidence_ref": {
          "type": "string"
        },
        "evidence_format": {
          "type": "string"
        },
        "appraisal": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
