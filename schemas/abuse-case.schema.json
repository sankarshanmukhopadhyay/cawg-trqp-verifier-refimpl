{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Abuse case",
  "type": "object",
  "required": [
    "id",
    "title",
    "legitimate_capability",
    "harm",
    "guardrails",
    "owner"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ABUSE-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "legitimate_capability": {
      "type": "string"
    },
    "harm": {
      "type": "string"
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
