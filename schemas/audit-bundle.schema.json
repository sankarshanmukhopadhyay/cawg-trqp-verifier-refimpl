{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/cawg-trqp-verifier-refimpl/schemas/audit-bundle.schema.json",
  "type": "object",
  "required": [
    "bundle_type",
    "bundle_profile",
    "bundle_version",
    "exported_at",
    "bundle_id",
    "bundle_digest_sha256",
    "request_summary",
    "verification_result",
    "policy_evidence",
    "process_appraisal",
    "replay_inputs"
  ],
  "properties": {
    "bundle_type": {
      "const": "cawg-trqp-audit-bundle"
    },
    "bundle_profile": {
      "type": "string"
    },
    "bundle_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "bundle_id": {
      "type": "string"
    },
    "bundle_digest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "request_summary": {
      "type": "object"
    },
    "verification_result": {
      "type": "object"
    },
    "policy_evidence": {
      "type": "object"
    },
    "process_appraisal": {
      "type": "object"
    },
    "gateway_mediation": {
      "type": "object"
    },
    "replay_inputs": {
      "type": "object",
      "required": [
        "request",
        "profile",
        "use_gateway",
        "verification_mode",
        "policy_epoch",
        "transport_metadata",
        "revocation_status",
        "replay_contract"
      ],
      "properties": {
        "request": {
          "type": "object"
        },
        "profile": {
          "oneOf": [
            {
              "enum": [
                "edge",
                "standard",
                "high_assurance"
              ]
            },
            {
              "type": "object",
              "required": [
                "id",
                "base_profile",
                "controls",
                "overlays",
                "source"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "base_profile": {
                  "enum": [
                    "edge",
                    "standard",
                    "high_assurance"
                  ]
                },
                "controls": {
                  "type": "object"
                },
                "overlays": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "source": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "use_gateway": {
          "type": "boolean"
        },
        "verification_mode": {
          "type": "string"
        },
        "policy_epoch": {
          "type": [
            "string",
            "null"
          ]
        },
        "policy_feed": {
          "type": "object",
          "properties": {
            "policy_source": {
              "type": "string"
            },
            "policy_source_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "revocation_source": {
              "type": "string"
            },
            "revocation_source_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "policy_descriptor_source": {
              "type": "string"
            },
            "revocation_descriptor_source": {
              "type": "string"
            },
            "trust_anchors_source": {
              "type": "string"
            },
            "policy_descriptor_source_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "revocation_descriptor_source_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "trust_anchors_source_sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "additionalProperties": false
        },
        "transport_metadata": {
          "type": "object"
        },
        "revocation_status": {
          "type": "object"
        },
        "replay_contract": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "bundle_attestation": {
      "type": "object",
      "properties": {
        "algorithm": {
          "const": "Ed25519"
        },
        "key_id": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
