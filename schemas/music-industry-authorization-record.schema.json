{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sankarshanmukhopadhyay.github.io/cawg-trqp-verifier-refimpl/schemas/music-industry-authorization-record.schema.json",
  "title": "Music-Industry Pilot Authorization Record",
  "description": "Non-normative authorization record for the authorized digital music delivery pilot.",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile", "authority_id", "issuer_id", "actor_id", "action", "resource", "scope", "valid_from", "valid_until", "status"],
  "properties": {
    "profile": {"const": "recorded-music-distribution-v1"},
    "authority_id": {"type": "string", "minLength": 1},
    "issuer_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "action": {"const": "distribute"},
    "resource": {"type": "string", "pattern": "^(isrc:|catalogue:)"},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["territories", "platforms"],
      "properties": {
        "territories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
        "platforms": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "delegation_allowed": {"type": "boolean"}
      }
    },
    "valid_from": {"type": "string", "format": "date-time"},
    "valid_until": {"type": "string", "format": "date-time"},
    "status": {"enum": ["active", "expired", "revoked", "suspended", "disputed"]},
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revoked_at", "reason_code", "evidence_ref"],
      "properties": {
        "revoked_at": {"type": "string", "format": "date-time"},
        "reason_code": {"type": "string", "minLength": 1},
        "evidence_ref": {"type": "string", "minLength": 1}
      }
    },
    "evidence_ref": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "revoked"}}},
      "then": {"required": ["revocation"]}
    }
  ]
}
