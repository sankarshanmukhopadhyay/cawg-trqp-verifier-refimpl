{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "asset_integrity",
    "trust_outcome"
  ],
  "properties": {
    "asset_integrity": {
      "type": "string"
    },
    "assertion_binding": {
      "type": "string"
    },
    "issuer_recognition": {
      "type": "string"
    },
    "actor_authorization": {
      "type": "string"
    },
    "policy_freshness": {
      "type": "string"
    },
    "verification_mode": {
      "type": "string"
    },
    "trust_outcome": {
      "type": "string"
    },
    "explanations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}