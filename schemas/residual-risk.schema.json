{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Residual risk acceptance",
  "type": "object",
  "required": [
    "risk_id",
    "title",
    "inherent_risk",
    "controls",
    "residual_risk",
    "accepted_by",
    "acceptance_expiry",
    "monitoring",
    "evidence"
  ],
  "properties": {
    "risk_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "inherent_risk": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "residual_risk": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "accepted_by": {
      "type": "string",
      "minLength": 3
    },
    "acceptance_expiry": {
      "type": "string",
      "format": "date"
    },
    "monitoring": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "reassessment_triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
